<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.expenses.repository.ReceiptMapper">

  <!-- ResultMap: Receiptエンティティのマッピング -->
  <resultMap id="receiptResultMap" type="com.example.expenses.domain.Receipt">
    <id property="id" column="id"/>
    <result property="expenseId" column="expense_id"/>
    <result property="originalFilename" column="original_filename"/>
    <result property="storedFilename" column="stored_filename"/>
    <result property="filePath" column="file_path"/>
    <result property="contentType" column="content_type"/>
    <result property="fileSize" column="file_size"/>
    <result property="uploadedBy" column="uploaded_by"/>
    <result property="uploadedAt" column="uploaded_at"/>
  </resultMap>

  <!-- INSERT: 領収書を保存 -->
  <insert id="insert" parameterType="com.example.expenses.domain.Receipt" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO receipts (
      expense_id,
      original_filename,
      stored_filename,
      file_path,
      content_type,
      file_size,
      uploaded_by,
      uploaded_at
    ) VALUES (
      #{expenseId},
      #{originalFilename},
      #{storedFilename},
      #{filePath},
      #{contentType},
      #{fileSize},
      #{uploadedBy},
      #{uploadedAt}
    )
  </insert>

  <!-- SELECT: 領収書IDで検索 -->
  <select id="findById" resultMap="receiptResultMap">
    SELECT
      id,
      expense_id,
      original_filename,
      stored_filename,
      file_path,
      content_type,
      file_size,
      uploaded_by,
      uploaded_at
    FROM
      receipts
    WHERE
      id = #{id}
  </select>

  <!-- SELECT: 経費IDで領収書一覧を取得 -->
  <select id="findByExpenseId" resultMap="receiptResultMap">
    SELECT
      id,
      expense_id,
      original_filename,
      stored_filename,
      file_path,
      content_type,
      file_size,
      uploaded_by,
      uploaded_at
    FROM
      receipts
    WHERE
      expense_id = #{expenseId}
    ORDER BY
      uploaded_at DESC
  </select>

  <!-- DELETE: 領収書を削除 -->
  <delete id="deleteById">
    DELETE FROM receipts
    WHERE id = #{id}
  </delete>

  <!-- SELECT: 経費IDに紐づく領収書の件数を取得 -->
  <select id="countByExpenseId" resultType="int">
    SELECT
      COUNT(*)
    FROM
      receipts
    WHERE
      expense_id = #{expenseId}
  </select>

</mapper>
